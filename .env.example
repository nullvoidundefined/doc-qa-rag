# Server
PORT=3001
CORS_ORIGIN=http://localhost:3000
CSRF_SECRET=# TODO: generate a random secret
NODE_ENV=development

# Database (Neon)
DATABASE_URL=# TODO: postgres connection string from Neon
DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Redis (local or Railway)
REDIS_URL=redis://localhost:6379

# Anthropic
ANTHROPIC_API_KEY=# TODO: key from console.anthropic.com

# OpenAI (embeddings)
OPEN_AI_API_KEY=# TODO: key from platform.openai.com
EMBEDDING_MODEL=text-embedding-3-small

# Cloudflare R2 (S3-compatible object storage). See docs/runbooks/cloudflare-r2.md.
# Use an R2 API token (R2 > Manage R2 API Tokens), Object Read & Write, scoped to this bucket.
# The server and worker services both need these four values.
R2_ACCESS_KEY_ID=# TODO: Access Key ID from the R2 API token
R2_SECRET_ACCESS_KEY=# TODO: Secret Access Key from the R2 API token
R2_ENDPOINT=# TODO: https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET_NAME=doc-qa-rag

# Worker
WORKER_PORT=3002

# Web client
NEXT_PUBLIC_API_URL=http://localhost:3001
