PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://user:password@host:5432/dbname
REDIS_URL=redis://localhost:6379
ANTHROPIC_API_KEY=sk-ant-...
# Cloudflare R2 (S3-compatible object storage). See docs/runbooks/cloudflare-r2.md.
# Use an R2 API token (R2 > Manage R2 API Tokens), Object Read & Write, scoped to this bucket.
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=doc-qa-rag
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
CSRF_SECRET=change-me-to-a-random-secret
